# ── App server ────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Frontend (Vite) — safe to expose in browser ─────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Dev: leave empty (Vite proxies /api). Production: set to your API origin or /api
VITE_API_URL=

# ── API / Supabase — never prefix with VITE_ ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
DATABASE_URL=postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres

# ── Admin login (comma-separated; one shared password) ────────────────────
ADMIN_EMAILS=admin1@yourchurch.org,admin2@yourchurch.org
ADMIN_USERNAMES=admin1,admin2
ADMIN_PASSWORD=change-me-min-6-chars

# ── Email (optional — contact/plan-visit notifications) ───────────────────
# RESEND_API_KEY=re_...
