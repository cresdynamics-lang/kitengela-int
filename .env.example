# Frontend (Vite) — safe to expose in browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API / Vercel serverless — never prefix with VITE_
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Easiest admin login on Vercel (no Supabase admins row required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-min-6-chars
ADMIN_EMAIL=admin@yourchurch.org
